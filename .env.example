# FCGBDS Customer System Configuration

# Server Configuration
PORT=3001
HOST=0.0.0.0

# Open Source - no license key required.

# API Integration (optional)
FCG_API_BASE_URL=https://PLACEHOLDER_API_BASE_URL
FCG_TELEMETRY_ENDPOINT=/api/fcgbds/telemetry
FCG_BLOCKCHAIN_ANCHOR_ENDPOINT=/api/fcgbds/telemetry
FCG_UPDATE_ENDPOINT=/api/fcgbds/updates

# Immutable datapoint anchoring
BLOCKCHAIN_ANCHOR_ENABLED=true
BLOCKCHAIN_ANCHOR_NETWORK=placeholder-mainnet
FCGBDS_INSTANCE_ID=your-instance-id

# Bot Defense Configuration
BOT_DEFENSE_ENABLED=true
BOT_DEFENSE_RUNTIME_MODE=zero-offload
BOT_DEFENSE_MAX_IP_HITS=20
BOT_DEFENSE_MAX_DEVICE_HITS=15
BOT_DEFENSE_MAX_PAYLOAD_HITS=8
BOT_DEFENSE_IP_WINDOW_MS=60000
BOT_DEFENSE_DEVICE_WINDOW_MS=60000
BOT_DEFENSE_PAYLOAD_WINDOW_MS=120000
BOT_DEFENSE_EXPECTED_HOSTNAME=PLACEHOLDER_API_HOST

# Protected Paths (comma-separated)
BOT_DEFENSE_PATHS=/api/auth/login,/api/auth/register,/api/auth/email/login,/api/auth/email/register,/api/user/profile,/api/payment

# Redis Configuration (optional, for distributed deployments)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LOG_FILE=logs/fcgbds.log

# Update Configuration
AUTO_UPDATE_ENABLED=true
UPDATE_CHECK_INTERVAL=3600000
UPDATE_BACKUP_ENABLED=true

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3002
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-this-password

# MSCB Bridge (Multi-Stream Chat Bridge)
MSCB_ENABLED=true
MSCB_ADAPTERS=twitch,kick,youtube,discord
MSCB_HEARTBEAT_MS=15000
MSCB_MAX_RECENT_EVENTS=100
# Optional: protect activate/deactivate endpoints.
MSCB_TRIGGER_KEY=change-this-mscb-trigger-key
