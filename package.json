{
  "name": "fcgbds-customer-system",
  "version": "1.0.0",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "description": "FCGBDS open-source bot defense system with middleware and Cloudflare worker templates",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "benchmark": "node scripts/benchmark/run-benchmark.mjs",
    "benchmark:quick": "node scripts/benchmark/run-benchmark.mjs --url http://127.0.0.1:3001/api/auth/login --connections 20 --duration 15 --method POST",
    "docker:build": "docker build -t fcgbds-customer .",
    "docker:run": "docker run -p 3001:3001 fcgbds-customer",
    "dashboard": "npm run build && node dist/dashboard.js"
  },
  "keywords": [
    "bot-defense",
    "bot-detection",
    "security",
    "middleware",
    "api-protection",
    "rate-limiting",
    "anti-cheat",
    "cloudflare",
    "redis",
    "typescript"
  ],
  "author": "CannaMuffinMan / Forever Couch Gang",
  "license": "MIT",
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "autocannon": "^7.15.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "semver": "^7.7.1",
    "winston": "^3.17.0"
  }
}
